{
  "JwtOptions": {
    "Secret": "super-secret-key-for-jwt-token-generation",
    "Issuer": "HMS_API",
    "Audience": "HMS_CLIENT",
    "ExpiryMinutes": 60
  },
  "ConnectionStrings": {
    "HmsDb": "Your_Database_Connection_String_Here"
  },
  "CloudinarySettings": {
    "CloudName": "your_cloud_name",
    "ApiKey": "your_api_key",
    "ApiSecret": "your_api_secret"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
